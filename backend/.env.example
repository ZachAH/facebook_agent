# Database
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Anthropic
ANTHROPIC_API_KEY=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
OWNER_PHONE_NUMBER=+1xxxxxxxxxx

# Facebook
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
# App ID + secret (developers.facebook.com -> app -> Settings -> Basic).
# Needed to mint a non-expiring page token with `npm run fb:token`, and lets
# the token health check inspect the token even after it expires.
FB_APP_ID=
FB_APP_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Auth
JWT_SECRET=
ADMIN_PASSWORD=

# App
FRONTEND_URL=https://your-site.netlify.app
PORT=3001
